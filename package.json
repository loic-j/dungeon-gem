{
  "name": "dungeon-crawler-gem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stage1-test": "VITE_DEV_STATE=stage1-test vite",
    "dev:stage1-end": "VITE_DEV_STATE=stage1-end vite",
    "dev:stage2-start": "VITE_DEV_STATE=stage2-start vite",
    "dev:boss": "VITE_DEV_STATE=boss vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "three": "^0.172.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/three": "^0.172.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  }
}
