{
  "name": "dungeon-crawler-gem",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": ["--shm-size=2gb"],
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },
  "remoteEnv": {
    "HOST_HOME": "${localEnv:HOME}"
  },
  "postCreateCommand": "bash .devcontainer/setup-claude.sh && pnpm install && npx playwright install chromium",
  "remoteUser": "node",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/tmp/.claude-host,type=bind,readonly,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/node/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached"
  ],
  "postStartCommand": "chmod 700 /home/node/.ssh && chmod 600 /home/node/.ssh/id_* 2>/dev/null || true"
}
